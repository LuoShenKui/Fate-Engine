{
  "name": "fate-door-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run build && pnpm run preview",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "preview": "python3 -m http.server 5173",
    "start": "pnpm run preview",
    "check:visual": "node tools/visual_regression.mjs",
    "check:visual:update": "node tools/visual_regression.mjs --update-baseline"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "packageManager": "pnpm@10.13.1"
}
