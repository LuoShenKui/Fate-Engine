{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "/tmp/fate-engine-composer-tests-dist"
  },
  "include": [
    "src/composer/**/*.ts",
    "tests/composer/**/*.ts"
  ]
}
