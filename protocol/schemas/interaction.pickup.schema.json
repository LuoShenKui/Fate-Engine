{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fate.interaction.pickup.schema.json",
  "type": "object",
  "required": ["reach_distance_m", "carry_mass_kg", "hold_offset_m", "unit_system"],
  "properties": {
    "reach_distance_m": { "type": "number", "minimum": 0.2, "maximum": 3.0 },
    "carry_mass_kg": { "type": "number", "minimum": 0.1, "maximum": 40.0 },
    "hold_offset_m": { "type": "number", "minimum": 0.1, "maximum": 1.5 },
    "unit_system": { "const": "metric" }
  },
  "additionalProperties": false
}
