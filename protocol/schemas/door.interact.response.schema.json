{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fate.protocol/door.interact.response.schema.json",
  "title": "Door Interact Response",
  "allOf": [
    {
      "$ref": "./envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "door.interact.response"
        },
        "payload": {
          "type": "object",
          "required": ["event", "payload"],
          "properties": {
            "event": {
              "type": "string",
              "minLength": 1
            },
            "payload": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
