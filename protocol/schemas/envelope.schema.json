{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fate.protocol/envelope.schema.json",
  "title": "Fate Protocol Envelope",
  "type": "object",
  "required": ["protocol_version", "type", "request_id", "payload"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "const": "1.0"
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    },
    "error": {
      "type": "object",
      "required": ["code", "message", "details"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
