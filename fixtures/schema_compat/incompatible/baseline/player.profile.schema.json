{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Player Profile",
  "version": "1.1.0",
  "type": "object",
  "properties": {
    "id": {"type": "string"},
    "nickname": {"type": "string"},
    "status": {"type": "string", "enum": ["online", "offline", "away"]},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "level": {"type": "integer"}
      }
    }
  },
  "required": ["id"]
}
