{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Player Profile",
  "version": "2.0.0",
  "type": "object",
  "properties": {
    "id": {"type": "integer"},
    "status": {"type": "string", "enum": ["online"]},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {"type": "integer"}
      }
    }
  },
  "required": ["id", "status"]
}
